{
  "templates": [
    {
      "id": "strategy-2day",
      "name": "Strategy Workshop",
      "workshopType": "strategy",
      "description": "Two-day workshop for defining vision, goals, and strategic direction. Focuses on alignment and big-picture thinking.",
      "duration": {
        "days": 2,
        "hoursPerDay": 4,
        "totalHours": 8,
        "flexible": true
      },
      "targetParticipants": {
        "min": 6,
        "max": 12,
        "ideal": 8
      },
      "rationale": {
        "why": "Strategy workshops need time for deep discussion, reflection, and alignment. Two days with a gap allows participants to process and come back with fresh perspective.",
        "structure": "Day 1 focuses on understanding the current state and defining the vision. Day 2 focuses on making decisions and planning next steps."
      },
      "days": [
        {
          "day": 1,
          "label": "Day 1: Understand & Define",
          "phase": "collect-choose",
          "totalMinutes": 240,
          "activities": [
            {
              "id": "expert-interview",
              "duration": 45,
              "required": true,
              "rationale": "Critical for gathering context and aligning on the problem space"
            },
            {
              "id": "sailboat",
              "duration": 35,
              "required": false,
              "rationale": "Helps identify what's working and what's holding the team back"
            },
            {
              "id": "lightning-demos",
              "duration": 60,
              "required": false,
              "rationale": "Inspiration from competitive landscape and existing patterns"
            },
            {
              "id": "long-term-goal",
              "duration": 35,
              "required": true,
              "rationale": "Sets the vision and key questions to answer"
            },
            {
              "id": "map",
              "duration": 30,
              "required": false,
              "rationale": "Organize ideas and find patterns"
            }
          ]
        },
        {
          "day": 2,
          "label": "Day 2: Decide & Plan",
          "phase": "choose-commit",
          "totalMinutes": 240,
          "activities": [
            {
              "id": "user-story-mapping",
              "duration": 90,
              "required": false,
              "rationale": "Define scope and prioritize initiatives"
            },
            {
              "id": "concept-creation",
              "duration": 60,
              "required": false,
              "rationale": "Create tangible concepts to evaluate"
            },
            {
              "id": "action-board",
              "duration": 25,
              "required": true,
              "rationale": "Always required - defines next steps and accountability"
            }
          ]
        }
      ]
    },
